{
    "name": "justbetter/statamic-cloudflare-purge",
    "description": "Addon that hooks into the statamic invalidation process and purges cloudflare caches",
    "keywords": [
        "statamic",
        "cloudflare",
        "caching"
    ],
    "homepage": "https://github.com/justbetter/statamic-cloudflare-purge",
    "license": "MIT",
    "authors": [
        {
            "name": "Jade Geels",
            "email": "jade@justbetter.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "justbetter/statamic-base": "^1.0",
        "laravel/framework": "^12.40|^13.0",
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^10.11|^11.0",
        "pestphp/pest": "^3.7",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "JustBetter\\StatamicCloudflarePurge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JustBetter\\StatamicCloudflarePurge\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "pixelfear/composer-dist-plugin": false
        }
    },
    "extra": {
        "statamic": {
            "name": "Cloudflare purge",
            "description": "Addon that hooks into the statamic invalidation process and purges cloudflare caches"
        },
        "laravel": {
            "providers": [
                "JustBetter\\StatamicCloudflarePurge\\StatamicCloudflarePurgeServiceProvider"
            ],
            "aliases": {
                "CloudflarePurge": "JustBetter\\StatamicCloudflarePurge\\CloudflarePurge"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan --memory-limit=1G",
        "style": "pint --test",
        "style:fix": "pint",
        "coverage": "XDEBUG_MODE=coverage php vendor/bin/pest --coverage --min=100",
        "quality": [
            "@test",
            "@analyse",
            "@style"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
